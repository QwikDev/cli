{
  "name": "@qwik.dev/cli",
  "version": "0.0.1",
  "type": "module",
  "description": "Qwik CLI - the official CLI for Qwik projects",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "qwik": "./dist/bin/qwik.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.mjs",
      "require": "./dist/src/index.cjs"
    }
  },
  "main": "./dist/src/index.cjs",
  "module": "./dist/src/index.mjs",
  "files": [
    "dist",
    "stubs"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "node --import tsx/esm bin/test.ts",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "cross-spawn": "^7.0.6",
    "fs-extra": "^11.3.0",
    "kleur": "^4.1.5",
    "magic-string": "^0.30",
    "oxc-parser": "^0.123",
    "panam": "^0.3.0",
    "which": "^5.0.0",
    "which-pm-runs": "^1.1.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@japa/assert": "^4.0.1",
    "@japa/runner": "^4.2.0",
    "@types/cross-spawn": "*",
    "@types/fs-extra": "*",
    "@types/node": "^24.0.0",
    "@types/which": "*",
    "@types/which-pm-runs": "*",
    "@types/yargs": "*",
    "tsdown": "^0.20.1",
    "tsx": "*",
    "typescript": "^5.8.3"
  }
}
